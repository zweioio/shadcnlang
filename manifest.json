{
  "manifest_version": 3,
  "name": "shadcn/ui 中文翻译",
  "version": "4.0.0",
  "description": "安装即用，自动将 shadcn/ui 官方文档翻译为简体中文。内置 3000+ 翻译条目，零网络请求，毫秒级完成。",
  "default_locale": "zh_CN",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://ui.shadcn.com/*"
  ],
  "action": {
    "default_title": "shadcn 翻译器"
  },
  "content_scripts": [
    {
      "matches": ["https://ui.shadcn.com/*"],
      "js": ["dict/zh-CN.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
