{
  "manifest_version": 3,
  "name": "shadcn/ui 翻译",
  "version": "4.0.0",
  "description": "shadcn/ui 中文翻译 - 字典 + API 混合翻译",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://ui.shadcn.com/*"
  ],
  "action": {
    "default_title": "shadcn 翻译器"
  },
  "content_scripts": [
    {
      "matches": ["https://ui.shadcn.com/*"],
      "js": ["dict/zh-CN.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
